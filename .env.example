# Image generation (set at least one provider key)
GEMINI_API_KEY=your_google_ai_studio_key
OPENAI_API_KEY=

# Which backend to use when both keys are set: gemini | openai | auto (default auto).
# auto: prefers GEMINI_API_KEY if set (matches older single-key setups), else OpenAI.
IMAGE_GENERATION_PROVIDER=auto

# Optional overrides (OpenAI path)
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_SIZE=1024x1024
# OPENAI_BASE_URL=https://api.openai.com

# Optional overrides (Gemini path)
# GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview

# Optional: protect all MCP tools with a static key.
# If set, include mcp_api_key in tool input.
MCP_STATIC_API_KEY=change-me-static-key

# Optional upload API (set this only if you want public URL upload)
UPLOAD_ENDPOINT=
UPLOAD_X_API_KEY=your_upload_static_api_key
UPLOAD_BEARER_TOKEN=

# Optional request headers for upload
ORIGIN=
REFERER=
