{
  "name": "@ideepakrajput/gemini-image-generator-mcp",
  "version": "1.0.1",
  "description": "MCP server for image generation via Gemini and/or OpenAI, with optional upload",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "gemini-image-generator-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist",
    "README.md",
    ".env.example"
  ],
  "keywords": [
    "mcp",
    "gemini",
    "image-generation",
    "upload",
    "cursor",
    "claude",
    "chatgpt"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ideepakrajput/gemini-image-generator-mcp.git"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^17.4.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20.19.40",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20"
  }
}
